# ── OpenAI ────────────────────────────────────────────────────────────────────
# API Key von OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Modellname, z.B. gpt-4o oder gpt-3.5-turbo
OPENAI_MODEL_NAME=gpt-4o

# ── Datenbank ─────────────────────────────────────────────────────────────────
# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:postgres@db:5432/aildb

# PostgreSQL Credentials (für den db-Service in docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aildb

# ── Authentifizierung ─────────────────────────────────────────────────────────
# Zufälliger, langer String für JWT-Signierung
# Generieren mit: openssl rand -hex 32
JWT_SECRET_KEY=

# Algorithmus für JWT-Signierung
JWT_ALGORITHM=HS256

# ── SMTP (Passwort-Reset E-Mails) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Absenderadresse für ausgehende E-Mails
MAIL_FROM=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Kommaseparierte Liste erlaubter Frontend-URLs (kein trailing slash)
# Lokal: http://localhost:3000,http://localhost:5173
# Produktion: https://ailv.fhtechnikum-example.at
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL des Backends aus Sicht des Browsers
# Lokal: http://localhost:8000
# Produktion: https://ailv.fhtechnikum-example.at/api
VITE_API_BASE=http://localhost:8000

# ── Sonstiges ─────────────────────────────────────────────────────────────────
# Swagger UI aktivieren (true = aktiviert, false = deaktiviert)
# In Produktion auf false setzen
ENABLE_DOCS=true